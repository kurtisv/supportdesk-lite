# ============================================================
# SupportDesk Lite — Environment Variables
# Copy this file to .env.local and fill in your own values.
# NEVER commit .env.local — it is listed in .gitignore.
# ============================================================

# App
NEXT_PUBLIC_APP_URL=http://localhost:3001
APP_NAME=SupportDesk Lite

# Supabase — https://supabase.com/dashboard/project/_/settings/api
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# Database (used only by Prisma CLI for migrations, not at runtime)
DATABASE_URL=postgresql://postgres.YOUR_PROJECT_REF:YOUR_PASSWORD@aws-0-ca-central-1.pooler.supabase.com:6543/postgres

# Auth.js — generate with: openssl rand -base64 32
AUTH_SECRET=replace_with_a_random_64_char_string
AUTH_URL=http://localhost:3001
AUTH_TRUST_HOST=true

# Demo login (set AUTH_ENABLE_DEMO_LOGIN=false to disable in production)
AUTH_ENABLE_DEMO_LOGIN=true
AUTH_DEMO_EMAIL=admin@example.com
AUTH_DEMO_PASSWORD=change_this_password

# GitHub OAuth (optional — leave blank to disable GitHub login)
AUTH_GITHUB_ID=
AUTH_GITHUB_SECRET=

# Admin bootstrap — comma-separated emails that can access the dashboard on first run
DASHBOARD_BOOTSTRAP_EMAILS=admin@example.com

# Email — https://resend.com/api-keys
RESEND_API_KEY=re_your_api_key_here
RESEND_FROM_EMAIL=noreply@yourdomain.com

# Keep-alive cron protection (set the same value in GitHub Actions secret PING_SECRET)
PING_SECRET=replace_with_random_string

# Feature flags
FEATURE_BOOKING=false
FEATURE_API_PORTAL=false
FEATURE_CMS=false
FEATURE_BILLING=false
